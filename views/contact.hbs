<h2>Contact me</h2>

{{#if isError}}
<div class="isError">
    <h3>"You can't leave fields empty!"</h3>
</div>
{{/if}}

{{#if isSent}}
<div class="isSent">
    <h3>"The message has been sent!" {{ fileName }} has been saved</h3>
</div>
{{/if}}

<form action="/contact/send-message" method="POST" enctype="multipart/form-data">
  <label>
    Your name: <input type="text" name="author">
  </label>
  <label>
    Your email: <input type="email" name="sender">
  </label>
  <label>
    Title: <input type="text" name="title">
  </label>
  <label>
    Project design: <input type="file" name="design" accept=".png, .jpg, .jpeg, .gif">
  </label>
   <label>
    Message: <textarea name="message"></textarea>
  </label>
  <button type="submit">Send message</button>
</form>
